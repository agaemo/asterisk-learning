# terraform.tfvars.example
# このファイルをコピーして terraform.tfvars を作成し、実際の値を入力してください。
# terraform.tfvars は .gitignore 対象です（絶対に git にコミットしないこと）

# 自分の IP アドレス（/32 形式）
# 確認方法: curl https://checkip.amazonaws.com
my_ip = "203.0.113.1/32"

# AWS コンソールで事前に作成した EC2 Key Pair の名前
key_name = "my-keypair"

# オプション（デフォルト値から変更する場合のみ記載）
# aws_region    = "ap-northeast-1"
# instance_type = "t3.micro"
